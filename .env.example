# =========================================================================
# KindCodex - Google Workspace (Gmail Business) SMTP Email Integration
# =========================================================================
# Follow these steps to enable email sending from august@kindcodex.com:
#
# 1. Log into your Google Workspace account and go to: https://myaccount.google.com/
# 2. Make sure 2-Step Verification is enabled under the Security tab.
# 3. Search for "App Passwords" in the search bar (or go directly to: https://myaccount.google.com/apppasswords).
# 4. Generate a new App Password (select App: "Other (custom name)", type "KindCodex Website").
# 5. Copy the 16-character code (e.g., "abcd efgh ijkl mnop") and use it for SMTP_PASS.
# 6. Paste these keys into your Vercel Project Environment Variables (under Project Settings > Environment Variables).
# =========================================================================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=august@kindcodex.com

# Paste your 16-character App Password here (no spaces, e.g., abcdefghijklmnop)
SMTP_PASS=your_16_character_app_password_here

SMTP_FROM=KindCodex <august@kindcodex.com>
